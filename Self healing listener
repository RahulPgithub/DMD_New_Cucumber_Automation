  // ─────────────────────────────────────────────────────────────────────────
  // Helpers
  // ─────────────────────────────────────────────────────────────────────────
  
  /**
  - Resolves a stable scenario ID from the TestNG result.
  - Uses className#methodName as the key — matches SelfHealingRetryAnalyzer.
    */
    private String resolveScenarioId(ITestResult result) {
    // Try to get Cucumber scenario ID from result attributes (set by hooks)
    Object scenarioId = result.getAttribute(“scenarioId”);
    if (scenarioId instanceof String s && !s.isBlank()) return s;
    
    // Fallback: stable key from class + method name
    return result.getTestClass().getName() + “#” + result.getName();
    }
  
  private String truncate(String s, int max) {
  if (s == null) return “”;
  return s.length() <= max ? s : s.substring(0, max - 3) + “…”;
  }
