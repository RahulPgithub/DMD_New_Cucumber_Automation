   // ── Step 2: build context ─────────────────────────────────────────────
   HealingContext ctx = buildContext(result, scenarioId, cause);
   System.out.printf("[SelfHealingListener]    → Sending to AI: %s %s%n",
           ctx.getMethod(), ctx.getEndpoint());
  
   // ── Step 3: call AI healing engine ────────────────────────────────────
   HealingSuggestion suggestion;
   try {
       suggestion = healingEngine.analyze(ctx);
   } catch (Exception e) {
       System.out.println("[SelfHealingListener]    ⚠ AI engine error: " + e.getMessage());
       HealingRegistry.markSkipped(scenarioId);
       return;
   }
  
   // ── Step 4: register suggestion ───────────────────────────────────────
   HealingRegistry.register(scenarioId, suggestion);
  
   if (suggestion.isHealable()) {
       System.out.printf("[SelfHealingListener]    ✅ AI suggestion registered:%n");
       System.out.printf("[SelfHealingListener]       Category  : %s%n",
               suggestion.getFailureCategory());
       System.out.printf("[SelfHealingListener]       Confidence: %.0f%%%n",
