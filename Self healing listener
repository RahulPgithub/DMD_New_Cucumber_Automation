  // Test failure — core healing trigger
  // ─────────────────────────────────────────────────────────────────────────
  
  @Override
  public void onTestFailure(ITestResult result) {
  Throwable cause = result.getThrowable();
  String scenarioId = resolveScenarioId(result);
  
