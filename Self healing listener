  // Suite start
  // ─────────────────────────────────────────────────────────────────────────
  
  @Override
  public void onStart(ITestContext context) {
  System.out.println(”[SelfHealingListener] 🤖 AI Self-Healing is ACTIVE for suite: “
  + context.getName());
  }
  
