           System.out.printf("[SelfHealingListener]       Path fix  : %s → %s%n",
                   suggestion.getOriginalPath(), suggestion.getSuggestedPath());
       }
       if (suggestion.hasEndpointFix()) {
           System.out.printf("[SelfHealingListener]       URL fix   : %s → %s%n",
                   suggestion.getOriginalEndpoint(), suggestion.getSuggestedEndpoint());
       }
       System.out.printf("[SelfHealingListener]       Reason    : %s%n",
               suggestion.getExplanation());
