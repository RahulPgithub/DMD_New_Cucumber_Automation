  // ─────────────────────────────────────────────────────────────────────────
  // isHealableFailure — structural failures only, never business logic
  // ─────────────────────────────────────────────────────────────────────────
  
  /**
  - Returns true ONLY for structural/environmental failures.
  - Business logic assertion failures (wrong value, wrong count etc.)
  - are NOT healable — they must fail and alert the team.
    */
    private boolean isHealableFailure(Throwable t) {
    if (t == null) return false;
    String msg  = t.getMessage() != null ? t.getMessage().toLowerCase() : “”;
    String type = t.getClass().getSimpleName().toLowerCase();
    
    // XPath failures
    if (msg.contains(“no results for path”))        return true;
    if (msg.contains(“xpath evaluation”))           return true;
    if (msg.contains(“nodelist is empty”))          return true;
    if (type.contains(“pathnotfound”))              return true;
    
    // JsonPath failures
    if (msg.contains(“jsonpath”))                   return true;
    if (msg.contains(“no value at json path”))      return true;
    
    // HTTP status mismatches that are likely env issues (not logic)
    if (msg.contains(“expected status code <200>”) &&
    msg.contains(“but was <404>”))              return true;  // endpoint moved
    if (msg.contains(“expected status code <200>”) &&
    msg.contains(“but was <503>”))              return true;  // env down
    if (msg.contains(“connection refused”))         return true;
    if (msg.contains(“connect timed out”))          return true;
    
    // Schema / field missing
    if (msg.contains(“nullpointerexception”) &&
    msg.contains(“response”))                   return true;
    
    // NOT healable — real assertion failures
    // msg.contains(“expected”) && msg.contains(“but found”) → real bug
    // msg.contains(“assertionError”) → real bug
    return false;
    }
  
  // ─────────────────────────────────────────────────────────────────────────
  // Build HealingContext from TestNG result
  // ─────────────────────────────────────────────────────────────────────────
  
  private HealingContext buildContext(ITestResult result,
  String scenarioId,
  Throwable cause) {
  // Try to get ApiRequestUtil from test instance (PicoContainer managed)
  // ApiRequestUtil stores rich context in ScenarioContext during execution
  Object testInstance = result.getInstance();
  if (testInstance != null) {
  try {
  // Reflection-based access — works with PicoContainer step defs
  java.lang.reflect.Field[] fields = testInstance.getClass().getDeclaredFields();
  for (java.lang.reflect.Field f : fields) {
  if (f.getType().equals(ApiRequestUtil.class)) {
  f.setAccessible(true);
  ApiRequestUtil util = (ApiRequestUtil) f.get(testInstance);
  if (util != null) {
  return util.buildHealingContext(result.getName(), cause);
  }
  }
  }
  } catch (Exception ignored) {
  // Fall through to minimal context
  }
  }
  
