/**

- TestNG listener that intercepts test failures and triggers AI self-healing.
- 
- Flow:
- onTestFailure  → check if healable → build HealingContext → call AI → register suggestion
- onTestSuccess  → if this was a retry, mark suggestion as HEALED
- onFinish       → print registry summary to console + CI logs
- 
- Register in testng-suites/*.xml:
- <listener class-name="com.dmd.api.listeners.SelfHealingListener"/>
- 
- Place at: src/test/java/com/dmd/api/listeners/SelfHealingListener.java
  */
  public class SelfHealingListener implements ITestListener {
  
  private final AiHealingEngine healingEngine = new AiHealingEngine();
  
