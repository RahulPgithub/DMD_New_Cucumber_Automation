package com.yourco.dmd.healing.model;

import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;

/**

- Represents the AI-generated self-healing suggestion for a failed test.
- Parsed from Anthropic API JSON response.
  */
  public class HealingSuggestion {
  
  // ── Enums ─────────────────────────────────────────────────────────────────
  
  public enum FailureCategory {
  ENDPOINT_CHANGED,
  SCHEMA_CHANGED,
  PATH_CHANGED,       // XPath / JsonPath selector changed
  AUTH_EXPIRED,
  ENV_ISSUE,
  REAL_BUG,
  UNKNOWN
  }
  
  public enum HealingStatus {
  PENDING,            // AI suggested a fix, not yet retried
  HEALED,             // Retry passed with AI suggestion
  FAILED_AGAIN,       // Retry also failed → real bug
  SKIPPED             // isHealable = false, no retry attempted
  }
  
  // ── Fields ────────────────────────────────────────────────────────────────
  
  private final String scenarioId;
  private final String testName;
  private final FailureCategory failureCategory;
  private final boolean healable;
  
  /** New XPath or JsonPath suggested by AI (null if not applicable) */
  private final String suggestedPath;
  
  /** Corrected endpoint URL suggested by AI (null if not applicable) */
  private final String suggestedEndpoint;
  
  /** Human-readable explanation from the AI */
  private final String explanation;
  
  /** Original path/endpoint that caused the failure */
  private final String originalPath;
  private final String originalEndpoint;
  
  /** Confidence score (0.0–1.0) optionally returned by AI */
  private final double confidence;
  
  /** Set after retry attempt */
  private HealingStatus status;
  private String retryError;
  
  private final String timestamp;
  
  // ── Constructor (use Builder) ─────────────────────────────────────────────
  
  private HealingSuggestion(Builder b) {
  this.scenarioId       = b.scenarioId;
  this.testName         = b.testName;
  this.failureCategory  = b.failureCategory;
  this.healable         = b.healable;
  this.suggestedPath    = b.suggestedPath;
  this.suggestedEndpoint = b.suggestedEndpoint;
  this.explanation      = b.explanation;
  this.originalPath     = b.originalPath;
  this.originalEndpoint = b.originalEndpoint;
  this.confidence       = b.confidence;
  this.status           = HealingStatus.PENDING;
  this.timestamp        = LocalDateTime.now()
  .format(DateTimeFormatter.ofPattern(“yyyy-MM-dd HH:mm:ss”));
  }
  
  // ── Factory: parse raw AI JSON string ────────────────────────────────────
  
  /**
  - Parses the JSON string returned by the Anthropic API.
  - Uses simple string extraction to avoid adding a JSON library dependency.
    */
    public static HealingSuggestion fromJson(String scenarioId, String testName,
    String originalPath, String originalEndpoint,
    String json) {
    Builder b = new Builder(scenarioId, testName);
    b.originalPath(originalPath)
    .originalEndpoint(originalEndpoint);
    
    try {
    b.healable(extractBoolean(json, “isHealable”))
    .failureCategory(parseCategory(extractString(json, “failureCategory”)))
    .suggestedPath(extractString(json, “suggestedPath”))
    .suggestedEndpoint(extractString(json, “suggestedEndpoint”))
    .explanation(extractString(json, “explanation”))
    .confidence(extractDouble(json, “confidence”, 0.8));
    } catch (Exception e) {
    b.healable(false)
    .failureCategory(FailureCategory.UNKNOWN)
    .explanation(“Failed to parse AI response: “ + e.getMessage());
    }
    
    return b.build();
    }
  
  // ── Mutators (set after retry) ────────────────────────────────────────────
  
  public void markHealed() {
  this.status = HealingStatus.HEALED;
  }
  
  public void markFailedAgain(String error) {
  this.status    = HealingStatus.FAILED_AGAIN;
  this.retryError = error;
  }
  
  public void markSkipped() {
  this.status = HealingStatus.SKIPPED;
  }
  
  // ── Accessors ─────────────────────────────────────────────────────────────
  
  public String getScenarioId()        { return scenarioId; }
  public String getTestName()          { return testName; }
  public FailureCategory getFailureCategory() { return failureCategory; }
  public boolean isHealable()          { return healable; }
  public String getSuggestedPath()     { return suggestedPath; }
  public String getSuggestedEndpoint() { return suggestedEndpoint; }
  public String getExplanation()       { return explanation; }
  public String getOriginalPath()      { return originalPath; }
  public String getOriginalEndpoint()  { return originalEndpoint; }
  public double getConfidence()        { return confidence; }
  public HealingStatus getStatus()     { return status; }
  public String getRetryError()        { return retryError; }
  public String getTimestamp()         { return timestamp; }
  
  public boolean hasPathFix()     { return suggestedPath     != null && !suggestedPath.isBlank(); }
  public boolean hasEndpointFix() { return suggestedEndpoint != null && !suggestedEndpoint.isBlank(); }
  
  // ── toString (for logging) ────────────────────────────────────────────────
  
  @Override
  public String toString() {
  return String.format(
  “[HealingSuggestion] scenario=%s | category=%s | healable=%s | status=%s | “ +
  “suggestedPath=’%s’ | suggestedEndpoint=’%s’ | confidence=%.2f | %s”,
  scenarioId, failureCategory, healable, status,
  suggestedPath, suggestedEndpoint, confidence, explanation
  );
  }
  
  // ── Internal JSON helpers (no-dep parsing) ────────────────────────────────
  
  private static String extractString(String json, String key) {
  String pattern = “"” + key + “"”;
  int idx = json.indexOf(pattern);
  if (idx < 0) return null;
  int colon = json.indexOf(”:”, idx + pattern.length());
  int start = json.indexOf(”"”, colon + 1);
  if (start < 0) return null;
  int end = json.indexOf(”"”, start + 1);
  return end < 0 ? null : json.substring(start + 1, end).trim();
  }
  
  private static boolean extractBoolean(String json, String key) {
  String pattern = “"” + key + “"”;
  int idx = json.indexOf(pattern);
  if (idx < 0) return false;
  int colon = json.indexOf(”:”, idx + pattern.length());
  String rest = json.substring(colon + 1).trim();
  return rest.startsWith(“true”);
  }
  
  private static double extractDouble(String json, String key, double defaultVal) {
  try {
  String pattern = “"” + key + “"”;
  int idx = json.indexOf(pattern);
  if (idx < 0) return defaultVal;
  int colon = json.indexOf(”:”, idx + pattern.length());
  String rest = json.substring(colon + 1).trim();
  int end = rest.indexOf(”,”);
  if (end < 0) end = rest.indexOf(”}”);
  return Double.parseDouble(rest.substring(0, end).trim());
  } catch (Exception e) {
  return defaultVal;
  }
  }
  
  private static FailureCategory parseCategory(String value) {
  if (value == null) return FailureCategory.UNKNOWN;
  try { return FailureCategory.valueOf(value.trim()); }
  catch (Exception e) { return FailureCategory.UNKNOWN; }
  }
  
  // ── Builder ───────────────────────────────────────────────────────────────
  
  public static class Builder {
  private final String scenarioId;
  private final String testName;
  private FailureCategory failureCategory = FailureCategory.UNKNOWN;
  private boolean healable = false;
  private String suggestedPath;
  private String suggestedEndpoint;
  private String explanation = “”;
  private String originalPath;
  private String originalEndpoint;
  private double confidence = 0.0;
  
  ```
   public Builder(String scenarioId, String testName) {
       this.scenarioId = scenarioId;
       this.testName   = testName;
   }
  
   public Builder failureCategory(FailureCategory v)  { this.failureCategory  = v; return this; }
   public Builder healable(boolean v)                  { this.healable          = v; return this; }
   public Builder suggestedPath(String v)              { this.suggestedPath     = v; return this; }
   public Builder suggestedEndpoint(String v)          { this.suggestedEndpoint = v; return this; }
   public Builder explanation(String v)                { this.explanation       = v; return this; }
   public Builder originalPath(String v)               { this.originalPath      = v; return this; }
   public Builder originalEndpoint(String v)           { this.originalEndpoint  = v; return this; }
   public Builder confidence(double v)                 { this.confidence        = v; return this; }
  
   public HealingSuggestion build() { return new HealingSuggestion(this); }
  ```
  
  }
  }
